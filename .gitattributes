# Normalize line endings: keep LF in the repo, let Git handle checkout per-OS.
* text=auto eol=lf

# Scripts that must stay LF even on Windows checkouts.
*.sh   text eol=lf
*.mjs  text eol=lf

# Windows batch/PowerShell scripts use CRLF.
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Binary assets — never normalize.
*.png  binary
*.ico  binary
*.icns binary
*.svg  text

# Collapse generated lockfiles in diffs/reviews.
package-lock.json -diff linguist-generated
